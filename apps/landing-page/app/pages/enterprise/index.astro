---
/*
 * /enterprise/ — Workspace for Teams contact-sales page.
 *
 * Reached from the desktop client's top-right "Workspace for Teams" chip
 * (apps/web EntryShell) and exists to validate demand for a team / workspace
 * edition. Left column: pitch + perks; right column: a lead form that POSTs to
 * the `/contact-sales` Pages Function, which fans the lead out to Feishu.
 *
 * Light Atelier Zero styling in lockstep with the rest of the marketing site
 * (the reference screenshot was dark; we keep the same two-column layout but
 * on the site's own light theme). en / zh / zh-tw authored; other locales fall
 * back to en. Localized routes are produced by `[locale]/enterprise/`.
 */
import Layout from '../../_components/sub-page-layout.astro';
import { localeFromPath } from '../../i18n';

const locale = localeFromPath(Astro.url.pathname);

type TeamSizeOption = { value: string; label: string };

type EnterpriseCopy = {
  metaTitle: string;
  metaDescription: string;
  h1: string;
  lead: string;
  perks: string[];
  logosTitle: string;
  formHeading: string;
  nameLabel: string;
  namePlaceholder: string;
  emailLabel: string;
  emailPlaceholder: string;
  companyLabel: string;
  companyPlaceholder: string;
  teamSizeLabel: string;
  teamSizePlaceholder: string;
  teamSizeOptions: TeamSizeOption[];
  useCaseLabel: string;
  useCaseHint: string;
  useCaseError: string;
  useCaseOptions: TeamSizeOption[];
  roleLabel: string;
  rolePlaceholder: string;
  messageLabel: string;
  messagePlaceholder: string;
  submitLabel: string;
  submittingLabel: string;
  successTitle: string;
  successBody: string;
  errorMessage: string;
  privacyNote: string;
  optional: string;
  requiredError: string;
  emailError: string;
};

