    useCaseOptions: [
      { value: 'product_design', label: '產品 / 應用設計' },
      { value: 'design_system', label: '設計系統' },
      { value: 'prototype', label: '原型 / 應用介面' },
      { value: 'marketing', label: '行銷 / 落地頁' },
      { value: 'deck', label: '簡報 / Deck' },
